{
  "name": "inest-phone",
  "version": "0.1.0",
  "private": true,
  "description": "Aplicacao oficial iNest Phone com Next.js, NestJS, PostgreSQL e Prisma ORM.",
  "scripts": {
    "prepare": "husky",
    "dev": "node scripts/run-env.mjs development pnpm --parallel dev:web dev:api",
    "dev:web": "pnpm --filter @inest/web dev",
    "dev:api": "pnpm --filter @inest/api start:dev",
    "start:api": "pnpm --filter @inest/api start",
    "dev:staging": "node scripts/run-env.mjs staging pnpm --parallel dev:web dev:api",
    "build": "pnpm build:web && pnpm build:api",
    "build:development": "node scripts/run-env.mjs development pnpm build",
    "build:staging": "node scripts/run-env.mjs staging pnpm build",
    "build:production": "node scripts/run-env.mjs production pnpm build",
    "build:web": "pnpm --filter @inest/web build",
    "build:api": "pnpm --filter @inest/api build",
    "lint": "pnpm lint:web && pnpm lint:api",
    "lint:web": "pnpm --filter @inest/web lint",
    "lint:api": "pnpm --filter @inest/api lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm typecheck:web && pnpm typecheck:api",
    "typecheck:web": "pnpm --filter @inest/web typecheck",
    "typecheck:api": "pnpm --filter @inest/api typecheck",
    "test:api": "pnpm --filter @inest/api test",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck",
    "env:check": "node scripts/check-env.mjs development && node scripts/check-env.mjs staging --allow-placeholders && node scripts/check-env.mjs production --allow-placeholders",
    "prisma:validate": "node scripts/run-env.mjs development prisma validate",
    "prisma:generate": "node scripts/run-env.mjs development prisma generate",
    "prisma:migrate": "node scripts/run-env.mjs development prisma migrate dev",
    "prisma:studio": "node scripts/run-env.mjs development prisma studio",
    "prisma:seed": "node scripts/run-env.mjs development prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "bcrypt": "^5.1.1",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prisma": "^6.11.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": [
      "prettier --write"
    ],
    "apps/web/**/*.{ts,tsx}": [
      "pnpm --filter @inest/web lint"
    ],
    "apps/api/src/**/*.ts": [
      "pnpm --filter @inest/api lint"
    ]
  },
  "packageManager": "pnpm@10.17.1"
}
