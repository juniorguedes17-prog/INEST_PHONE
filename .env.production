# Ambiente
NODE_ENV="production"
APP_ENV="production"

# URLs
FRONTEND_URL="https://app.inestphone.com.br"
BACKEND_URL="https://api.inestphone.com.br"
NEXT_PUBLIC_API_URL="https://api.inestphone.com.br/api/v1"

# Backend
API_PORT="3333"
PORT="3333"
API_PREFIX="api/v1"
API_VERSION="1.0.0"
CORS_ORIGIN="https://app.inestphone.com.br"
LOG_LEVEL="warn"
SWAGGER_ENABLED="false"

# Banco de Dados
POSTGRES_DB="inest_phone"
POSTGRES_USER="replace-with-production-user"
POSTGRES_PASSWORD="replace-with-production-password"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/inest_phone?schema=public&sslmode=require&connection_limit=10&pool_timeout=20"

# Autenticacao
JWT_SECRET="replace-with-production-secret"
JWT_REFRESH_SECRET="replace-with-production-refresh-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Seed
SEED_ADMIN_EMAIL="admin@inestphone.local"
SEED_ADMIN_PASSWORD="replace-before-production"

# Google Sheets
GOOGLE_SHEETS_ENABLED="true"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_SHEETS_ID=""
GOOGLE_SHEETS_SPREADSHEET_ID="1Q-7UCn_t8yvwqmc5yo856wlKuCmMzH8S0pVwrl4kmeo"
GOOGLE_SHEETS_CLIENT_EMAIL=""
GOOGLE_SHEETS_PRIVATE_KEY=""
GOOGLE_SHEETS_RANGE="'Controle de Venda'!A:AZ"
GOOGLE_SHEETS_PROFIT_SPREADSHEET_ID="1uo0eD7mj-l-CMGGOhPatGqzNUt3dBHlZ8RJB2aZkAgo"
GOOGLE_SHEETS_PROFIT_RANGE="'BD LUCRO LIQUIDO'!A:D"

# WhatsApp
WHATSAPP_ENABLED="false"
WHATSAPP_BASE_URL="https://wa.me"
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_DEFAULT_MESSAGE="Ola, tenho interesse neste produto."

# NextAuth / Auth futura
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://app.inestphone.com.br"

# SMTP
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="no-reply@inestphone.com.br"

# Observabilidade
SENTRY_DSN=""
BETTER_STACK_SOURCE_TOKEN=""

# IA / Providers externos
OPENAI_API_KEY=""
IMPORT_PROVIDER_KEY=""
