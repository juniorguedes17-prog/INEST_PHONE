# Ambiente
NODE_ENV="production"
APP_ENV="staging"

# URLs
FRONTEND_URL="https://staging.inestphone.com.br"
BACKEND_URL="https://api-staging.inestphone.com.br"
NEXT_PUBLIC_API_URL="https://api-staging.inestphone.com.br/api/v1"

# Backend
API_PORT="3333"
PORT="3333"
API_PREFIX="api/v1"
API_VERSION="1.0.0"
CORS_ORIGIN="https://staging.inestphone.com.br"
LOG_LEVEL="log"
SWAGGER_ENABLED="true"

# Banco de Dados
POSTGRES_DB="inest_phone_staging"
POSTGRES_USER="replace-with-staging-user"
POSTGRES_PASSWORD="replace-with-staging-password"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/inest_phone_staging?schema=public&sslmode=require&connection_limit=10&pool_timeout=20"

# Autenticacao
JWT_SECRET="replace-with-staging-secret"
JWT_REFRESH_SECRET="replace-with-staging-refresh-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Seed
SEED_ADMIN_EMAIL="admin@inestphone.local"
SEED_ADMIN_PASSWORD="replace-before-staging"

# Google Sheets
GOOGLE_SHEETS_ENABLED="false"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_SHEETS_ID=""
GOOGLE_SHEETS_SPREADSHEET_ID=""
GOOGLE_SHEETS_CLIENT_EMAIL=""
GOOGLE_SHEETS_PRIVATE_KEY=""

# WhatsApp
WHATSAPP_ENABLED="false"
WHATSAPP_BASE_URL="https://wa.me"
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_DEFAULT_MESSAGE="Ola, tenho interesse neste produto."

# NextAuth / Auth futura
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://staging.inestphone.com.br"

# SMTP
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="no-reply@inestphone.com.br"

# Observabilidade
SENTRY_DSN=""
BETTER_STACK_SOURCE_TOKEN=""

# IA / Providers externos
OPENAI_API_KEY=""
IMPORT_PROVIDER_KEY=""
